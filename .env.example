# Neon PostgreSQL (password मध्ये @ असेल तर URL encode करा: %40)
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

OPENAI_API_KEY=

# 1 = POST /api/ai/generate returns 200 without OpenAI (echo mock). Remove when using real key.
MOCK_AI=1

# Optional: CORS_ORIGINS=http://localhost:9002,http://127.0.0.1:9002
